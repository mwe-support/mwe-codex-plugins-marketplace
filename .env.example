# GitHub token used only by the local web API to create submission tracking issues.
# Keep the real value in .env or your shell environment, never in git.
GITHUB_TOKEN=

# Admin password used by the web API for marketplace owner actions such as
# deleting listed plugins, removing failed submissions, or manually approving
# a failed upload request. Never commit the real value.
MARKETPLACE_ADMIN_PASSWORD=
# Short alias also supported by server/compose. Use either this or MARKETPLACE_ADMIN_PASSWORD.
ADMIN_PASSWORD=

# PostgreSQL live state source for web UI.
POSTGRES_DB=mwe_codex_marketplace
POSTGRES_USER=mwe_marketplace
POSTGRES_PASSWORD=mwe_marketplace_dev
DATABASE_URL=postgres://mwe_marketplace:mwe_marketplace_dev@postgres:5432/mwe_codex_marketplace
