{
  "name": "mwe-codex-plugins-marketplace",
  "version": "1.0.0",
  "description": "MWE Codex插件共享市场：粘贴公开 GitHub 仓库链接，服务端检测 Codex 插件结构，通过后实时显示在网页市场。",
  "main": "server.mjs",
  "scripts": {
    "start": "node server.mjs",
    "build": "tsc && cp dist/app.js app.js",
    "check": "npm run build && node --check app.js && node --check server.mjs && node --check db.mjs && npm run test:ui",
    "db:migrate": "node scripts/db-migrate.mjs",
    "test:ui": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mwe-support/mwe-codex-plugins-marketplace.git"
  },
  "keywords": [
    "codex",
    "plugins",
    "marketplace"
  ],
  "author": "MWE Support",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mwe-support/mwe-codex-plugins-marketplace/issues"
  },
  "homepage": "https://github.com/mwe-support/mwe-codex-plugins-marketplace#readme",
  "dependencies": {
    "pg": "^8.22.0"
  },
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "typescript": "^6.0.3"
  }
}
