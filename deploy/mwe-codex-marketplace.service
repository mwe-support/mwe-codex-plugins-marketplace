[Unit]
Description=MWE Codex Plugin Sharing Marketplace web container
After=default.target

[Service]
Type=oneshot
WorkingDirectory=/home/marvel/mwe-codex-plugins-marketplace
RemainAfterExit=yes
ExecStart=/usr/bin/docker compose up -d --build
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=300

[Install]
WantedBy=default.target
